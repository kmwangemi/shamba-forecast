# Copy this file to .env and fill in your real values. Never commit .env.

# WeatherAI API key (get one from https://weather-ai.co dashboard -> API Keys)
WEATHERAI_API_KEY=wai_your_key_here

# Base URL for the WeatherAI API
WEATHERAI_BASE_URL=https://api.weather-ai.co

# Port the Express server listens on
PORT=5000

# Cache TTL in seconds - how long a location's weather data is cached
CACHE_TTL_SECONDS=900

# Allowed origin for CORS (your frontend URL). Use * for local dev.
CORS_ORIGIN=*

# --- Firebase Admin SDK (optional) ---
# Used to log forecast requests to Firestore for analytics/debugging.
# Generate a service account key from:
# Firebase console -> Project settings -> Service accounts -> Generate new private key
# Then either:
#  (a) set FIREBASE_SERVICE_ACCOUNT_JSON to the full JSON as a single line, OR
#  (b) set GOOGLE_APPLICATION_CREDENTIALS to a path to the downloaded JSON file.
# Leave both unset to run without Firebase; the app works fine either way.
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_PROJECT_ID=
